#: lib/config_file.c:583
#, c-format
msgid "gFTP Warning: Skipping line %d in config file: %s\n"
msgstr "gFTP Uyarısı: Yapılandırma dosyasındaki %d satırı atlanıyor: %s\n"

#: lib/config_file.c:590
#, c-format
msgid "gFTP Warning: Cannot open %s for writing: %s\n"
msgstr "gFTP Uyarısı: %s dosyası yazmak için açılamadı: %s\n"

#: lib/config_file.c:645
msgid ""
"Note: The passwords contained inside this file are scrambled. This algorithm "
"is not secure. This is to avoid your password being easily remembered by "
"someone standing over your shoulder while you're editing this file. Prior to "
"this, all passwords were stored in plaintext."
msgstr ""
"Not: Bu dosyanın içindeki parolalar karıştırılmıştır. Bu algoritma güvenli "
"değildir. Parolanızın, siz bu dosyayı düzenlerken ekrana bakan herhangi "
"birisi tarafından kolaylıkla hatırlanmasını engellemek içindir. Bundan önce, "
"tüm parolalar düz metin olarak saklanıyordu."

#: lib/config_file.c:740
#, fuzzy
msgid ""
"gFTP. Warning: Any comments that you add to this file WILL be overwritten. "
"If a entry has a (*) in it's comment, you can't change it inside gFTP"
msgstr ""
"gFTP için yapılandırma dosyası. Telif Hakkı (C) 1998-2007 Brian Masney "
"<masneyb@gftp.org>. Uyarı: Bu dosyaya ekleyeceğiniz herhangi bir yorumun "
"üzerine yazılacaktır. Eğer bir girdinin yorumunda (*) varsa gFTP içinden "
"değiştiremezsiniz"

#: lib/config_file.c:1104 lib/protocols.c:378
