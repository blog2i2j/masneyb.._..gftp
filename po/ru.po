msgstr "Ошибка: недопустимая строка %s в файле индекса кэша\n"

#: lib/cache.c:140 lib/protocol_localfs.c:576
#, c-format
msgid "Error: Could not make directory %s: %s\n"
msgstr "Ошибка: Невозможно создать каталог %s: %s\n"

#: lib/cache.c:166
#, c-format
msgid "Error: Cannot create temporary file: %s\n"
msgstr "Ошибка: Невозможно создать временный файл: %s\n"

#: lib/cache.c:188 lib/cache.c:238 lib/config_file.c:160 lib/config_file.c:166
#: lib/protocol_http.c:306 lib/protocol_localfs.c:159
#: lib/protocol_localfs.c:287 lib/sshv2.c:1242
#, c-format
