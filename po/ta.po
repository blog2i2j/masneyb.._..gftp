#: lib/config_file.c:146 lib/sockutils.c:315 lib/sslcommon.c:630
#, c-format
msgid "Error: Could not write to socket: %s\n"
msgstr "பிழை: துளையில் எழுத இயலவில்லை: %s\n"

#: lib/config_file.c:154 lib/sockutils.c:236 lib/sshv2.c:457
#: lib/sslcommon.c:578
#, c-format
