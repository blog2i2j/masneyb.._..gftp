#: src/uicommon/gftpui.c:1022
msgid "Show current remote directory"
msgstr "ଚଳିତ ଦୂରବର୍ତ୍ତୀ ବିବରଣୀ ପଞ୍ଜିକା ଦେଖାନ୍ତୁ"

