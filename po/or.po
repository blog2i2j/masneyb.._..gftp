#: src/uicommon/gftpui.c:1026
msgid "Rename a remote file"
msgstr "ଏକ ଦୂରବର୍ତ୍ତୀ ଫାଇଲକୁ ପୁନଃନାମକରଣ କରନ୍ତୁ"

#: src/uicommon/gftpui.c:1028
