msgstr "預設會進行排序的欄位"

#: lib/options.h:201 lib/options.h:207
msgid "Sort ascending or descending"
msgstr "順序或反序排列"

#: lib/options.h:211 lib/options.h:229
msgid ""
"The width of the filename column in the file listboxes. Set this to 0 to "
