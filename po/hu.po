msgstr "AUTHENTICATE"

#: lib/protocol_ftp.c:37
msgid "user@host port"
msgstr "felh@gép port"

#: lib/protocol_ftp.c:38
msgid "user@host NOAUTH"
msgstr "felh@gép NOAUTH"

#: lib/protocol_ftp.c:39
msgid "Custom"
msgstr "Egyéni"

#: lib/protocol_ftp.c:48
msgid "Email address:"
msgstr "E-mail cím:"

#: lib/protocol_ftp.c:50
msgid ""
"This is the password that will be used whenever you log into a remote FTP "
"server as anonymous"
msgstr ""
"Távoli kiszolgálóra névtelen bejelentkezéskor mindig ez a jelszó lesz "
"használva"

#: lib/protocol_ftp.c:52
msgid "Proxy hostname:"
msgstr "Proxy gépneve:"

#: lib/protocol_ftp.c:54
msgid "Firewall hostname"
msgstr "Tűzfal gépneve"

#: lib/protocol_ftp.c:55
msgid "Proxy port:"
msgstr "Proxy port:"

#: lib/protocol_ftp.c:57
msgid "Port to connect to on the firewall"
msgstr "Tűzfalhoz kapcsolódás portja"

#: lib/protocol_ftp.c:58
msgid "Proxy username:"
msgstr "Felhasználónév a proxyhoz:"

#: lib/protocol_ftp.c:60
msgid "Your firewall username"
msgstr "Felhasználónév a tűzfalhoz"

#: lib/protocol_ftp.c:61
msgid "Proxy password:"
msgstr "Jelszó a proxyhoz:"

#: lib/protocol_ftp.c:63
msgid "Your firewall password"
msgstr "Jelszó a tűzfalhoz"

#: lib/protocol_ftp.c:64
msgid "Proxy account:"
msgstr "Proxy felhasználói fiók:"

